# Python
backend/venv/
backend/__pycache__/
backend/app/__pycache__/
backend/app/**/__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.eggs/
dist/
build/

# Database — do not commit real data
backend/*.db
backend/*.db-shm
backend/*.db-wal
*.db
*.db-shm
*.db-wal

# Environment — use .env.example as template
backend/.env

# Node / Frontend
frontend/node_modules/
frontend/dist/
frontend/.env
frontend/.env.local
frontend/.env.*.local

# Uploads (preserve folder structure, not files)
uploads/invoices/*
!uploads/invoices/.gitkeep

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo
