{
  "name": "pagacuotas",
  "version": "1.0.0",
  "description": "Sistema de gestión de cuotas y pagos — Integrado con SIS.CONTABLE, CRM y múltiples proveedores de pago",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --port=3002 --host=0.0.0.0",
    "server": "tsx watch server/index.ts",
    "start:server": "tsx server/index.ts",
    "start": "concurrently -n server,client -c blue,green \"npm run server\" \"npm run dev\"",
    "postinstall": "prisma generate",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:reset": "prisma db push --force-reset",
    "config:production:check": "tsx scripts/check-production-config.ts",
    "integration:test": "tsx scripts/integration-test.ts",
    "integration:simulate-flow": "tsx scripts/simulate-payment-flow.ts"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@prisma/client": "^6.2.1",
    "@tailwindcss/vite": "^4.1.14",
    "@types/cors": "^2.8.19",
    "@types/morgan": "^1.9.10",
    "@vitejs/plugin-react": "^5.0.4",
    "axios": "^1.16.0",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.1",
    "express-validator": "^7.3.2",
    "helmet": "^8.1.0",
    "lucide-react": "^0.546.0",
    "morgan": "^1.10.1",
    "motion": "^12.23.24",
    "prisma": "^6.2.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.14.2",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0",
    "tsx": "^4.21.0",
    "vite": "^6.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
