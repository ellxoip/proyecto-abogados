  CORRIENTE
  AHORRO
  VISTA
  CREDITO
}

enum TipoMovimientoTesoreria {
  INGRESO
  EGRESO
}

enum EstadoEgreso {
  PENDIENTE
  APROBADO
  PAGADO
  RECHAZADO
}

enum EstadoConciliacion {
  EN_PROCESO
  CONCILIADO
  CON_DIFERENCIAS
}

enum EstadoRendicion {
  BORRADOR
  ENVIADA
  APROBADA
  RECHAZADA
}

enum EstadoReposicion {
  PENDIENTE
  APROBADA
  PAGADA
  RECHAZADA
}

enum TipoDocumentoVenta {
  BOLETA
  FACTURA_EXENTA
  FACTURA_AFECTA
  NOTA_CREDITO
  NOTA_DEBITO
  COMPROBANTE_INGRESO
}

enum EstadoDocVenta {
  EMITIDO
  ACEPTADO_SII
  RECLAMADO
  ANULADO
  PAGADO
}

enum TipoDocumentoCompra {
  FACTURA
  BOLETA
  NOTA_CREDITO_RECIBIDA
  NOTA_DEBITO_RECIBIDA
}

enum EstadoDocCompra {
  RECIBIDO
  VALIDADO
  ACEPTADO
  RECLAMADO
  ANULADO
}

enum EstadoPagoGasto {
  PENDIENTE
  APROBADO
  PAGADO
  RECHAZADO
}

enum EstadoCxP {
  PENDIENTE
  PAGADA
  VENCIDA
  ANULADA
}

enum TipoCuentaContable {
  ACTIVO
  PASIVO
  PATRIMONIO
  INGRESO
  GASTO
  COSTO
}

enum NaturalezaCuenta {
  DEUDORA
  ACREEDORA
}

enum TipoMovimientoContable {
  DEBE
  HABER
}

enum EstadoComprobante {
  BORRADOR
  APROBADO
  ANULADO
}

enum TipoCierre {
  MENSUAL
  ANUAL
}
