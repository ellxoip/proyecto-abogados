generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Usuario {
  id                     Int                    @id @default(autoincrement())
  empresa_id             Int?
  nombre                 String                 @db.VarChar(120)
  email                  String                 @unique @db.VarChar(180)
  password_hash          String                 @db.VarChar(255)
  rol                    RolUsuario             @default(CONTADOR)
  activo                 Boolean                @default(true)
  created_at             DateTime               @default(now())
  updated_at             DateTime               @updatedAt
  import_batches         ClientImportBatch[]
  aprobaciones           ModificacionContrato[] @relation("ModificacionesAprobadasPor")
  modificaciones         ModificacionContrato[] @relation("ModificacionesPorUsuario")
  compromisos            CompromisoPago[]
  gestiones              GestionCobranza[]
  fondos_caja            FondoCajaChica[]       @relation("FondoResponsable")
  gastos_caja            GastoCajaChica[]       @relation("GastoCajaResponsable")
  rendiciones_aprobadas  RendicionCajaChica[]   @relation("RendicionesAprobadas")
  reposiciones_aprobadas ReposicionCajaChica[]  @relation("ReposicionesAprobadas")
  comprobantes_contables ComprobanteContable[]  @relation("ComprobanteUsuario")
  comprobantes_aprobados ComprobanteContable[]  @relation("ComprobanteAprobador")
  cierres_contables      CierreContable[]
}

model Cliente {
  id                           Int                  @id @default(autoincrement())
  empresa_id                   Int?
  rut                          String               @unique @db.VarChar(20)
  nombre                       String               @db.VarChar(200)
  tipo_cliente                 TipoCliente
  telefono                     String?              @db.VarChar(30)
  email                        String?              @db.VarChar(180)
  fecha_ingreso                DateTime             @db.Date
  estado                       EstadoCliente        @default(ACTIVO)
  portal_password_hash         String?
  portal_password_updated_at   DateTime?
  portal_password_last_sent_at DateTime?
  created_at                   DateTime             @default(now())
  updated_at                   DateTime             @updatedAt
  casos_legales                CasoLegal[]
  client_import_items          ClientImportItem[]
  contactos                    ClienteContacto[]
  cuota_warnings               CuotaWarning[]
  datos_facturacion            ClienteFacturacion[]
  contratos                    Contrato[]
  pagos                        Pago[]
  compromisos                  CompromisoPago[]
  gestiones                    GestionCobranza[]
  documentos_venta             DocumentoVenta[]
  reglas_facturacion           ReglaFacturacion[]

  @@index([empresa_id])
}

model Contrato {
  id                       Int                    @id @default(autoincrement())
  cliente_id               Int
  external_id              String?                @unique @db.VarChar(80)
  tipo_servicio            String                 @db.VarChar(200)
  fecha_contrato           DateTime               @db.Date
  monto_ccto               Decimal                @db.Decimal(14, 2)
  monto_pago_inicial       Decimal                @db.Decimal(14, 2)
  saldo_financiado         Decimal                @db.Decimal(14, 2)
  cantidad_cuotas_original Int
  estado                   EstadoContrato         @default(ACTIVO)
  crm_lead_id              Int?
  crm_opportunity_id       String?                @unique @db.VarChar(120)
  correlation_id           String?                @db.VarChar(120)
  idempotency_key          String?                @unique @db.VarChar(200)
  observaciones            String?
  created_at               DateTime               @default(now())
  updated_at               DateTime               @updatedAt
  casos_legales            CasoLegal[]
  contract_import_items    ContractImportItem[]
  cliente                  Cliente                @relation(fields: [cliente_id], references: [id])
  cuota_warnings           CuotaWarning[]
  cuotas                   Cuota[]
  modificaciones           ModificacionContrato[]
  pagos                    Pago[]
  compromisos              CompromisoPago[]
  gestiones                GestionCobranza[]

  @@unique([cliente_id, tipo_servicio, monto_ccto, fecha_contrato])
  @@index([cliente_id])
  @@index([estado])
}

model Cuota {
  id                       Int                     @id @default(autoincrement())
  contrato_id              Int
  caso_legal_id            Int?
  numero_cuota             Int
  fecha_vencimiento        DateTime                @db.Date
  monto_original           Decimal                 @db.Decimal(14, 2)
  monto_actual             Decimal                 @db.Decimal(14, 2)
  monto_pagado             Decimal                 @default(0) @db.Decimal(14, 2)
  saldo_pendiente          Decimal                 @db.Decimal(14, 2)
  estado                   EstadoCuota             @default(PENDIENTE)
  cobrable                 Boolean                 @default(true)
  motivo_no_cobrable       String?                 @db.VarChar(80)
  fecha_pago               DateTime?               @db.Date
  last_warning_level       CuotaWarningLevel?
  last_warning_at          DateTime?
  created_at               DateTime                @default(now())
  updated_at               DateTime                @updatedAt
  aplicaciones_pago        AplicacionPago[]
  caso_legal               CasoLegal?              @relation(fields: [caso_legal_id], references: [id])
  contrato                 Contrato                @relation(fields: [contrato_id], references: [id])
  installment_import_items InstallmentImportItem[]
  modificaciones           ModificacionContrato[]
  pagos                    Pago[]
  warnings                 CuotaWarning[]
  compromisos              CompromisoPago[]

  @@unique([contrato_id, numero_cuota])
  @@index([caso_legal_id])
  @@index([contrato_id, estado])
  @@index([fecha_vencimiento])
}

model Pago {
  id                Int              @id @default(autoincrement())
  cliente_id        Int
  contrato_id       Int
  cuota_id          Int?
  fecha_pago        DateTime         @db.Date
  monto_pagado      Decimal          @db.Decimal(14, 2)
  estado            EstadoPago       @default(CONFIRMADO)
  medio_pago        String           @db.VarChar(60)
  payment_event_id  String?          @db.VarChar(120)
  referencia        String?          @db.VarChar(120)
  comprobante_url   String?          @db.VarChar(500)
  observacion       String?
  created_at        DateTime         @default(now())
  updated_at        DateTime         @default(now()) @updatedAt
  aplicaciones_pago AplicacionPago[]
  cliente           Cliente          @relation(fields: [cliente_id], references: [id])
  contrato          Contrato         @relation(fields: [contrato_id], references: [id])
  cuota             Cuota?           @relation(fields: [cuota_id], references: [id], onDelete: Restrict)

  @@index([cliente_id, fecha_pago])
  @@index([contrato_id, fecha_pago])
  @@index([cuota_id])
  @@index([estado])
  @@index([payment_event_id])
}

model ModificacionContrato {
  id                 Int              @id @default(autoincrement())
  contrato_id        Int
  cuota_id           Int?
  usuario_id         Int
  tipo_modificacion  TipoModificacion
  fecha_modificacion DateTime         @db.Date
  valor_anterior     Json
  valor_nuevo        Json
  motivo             String
  aprobado_por       Int?
  created_at         DateTime         @default(now())
  aprobador          Usuario?         @relation("ModificacionesAprobadasPor", fields: [aprobado_por], references: [id], onDelete: Restrict)
  contrato           Contrato         @relation(fields: [contrato_id], references: [id])
  cuota              Cuota?           @relation(fields: [cuota_id], references: [id], onDelete: Restrict)
  usuario            Usuario          @relation("ModificacionesPorUsuario", fields: [usuario_id], references: [id])

  @@index([contrato_id, fecha_modificacion])
  @@index([usuario_id])
  @@index([aprobado_por])
}

model CasoLegal {
  id             Int       @id @default(autoincrement())
  cliente_id     Int
  contrato_id    Int?
  codigo_interno String?   @unique @db.VarChar(80)
  titulo         String    @db.VarChar(200)
  descripcion    String?
  estado         String    @default("ABIERTO") @db.VarChar(40)
  fecha_apertura DateTime  @default(now()) @db.Date
  fecha_cierre   DateTime? @db.Date
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt
  cliente        Cliente   @relation(fields: [cliente_id], references: [id])
  contrato       Contrato? @relation(fields: [contrato_id], references: [id])
  cuotas         Cuota[]

  @@index([cliente_id])
  @@index([contrato_id])
  @@index([estado])
}

model AplicacionPago {
  id             Int      @id @default(autoincrement())
  pago_id        Int
  cuota_id       Int
  monto_aplicado Decimal  @db.Decimal(14, 2)
  created_at     DateTime @default(now())
  cuota          Cuota    @relation(fields: [cuota_id], references: [id])
  pago           Pago     @relation(fields: [pago_id], references: [id], onDelete: Cascade)

  @@unique([pago_id, cuota_id])
  @@index([cuota_id])
}

model SistemaExterno {
  id                  Int                 @id @default(autoincrement())
  codigo              String              @unique @db.VarChar(40)
  nombre              String              @db.VarChar(120)
  base_url            String?             @db.VarChar(500)
  activo              Boolean             @default(true)
  created_at          DateTime            @default(now())
  updated_at          DateTime            @updatedAt
  external_references ExternalReference[]
  external_sync_logs  ExternalSyncLog[]
  integration_events  IntegrationEvent[]
}

model ExternalReference {
  id                    Int                @id @default(autoincrement())
  sistema_externo_id    Int
  entity_type           ExternalEntityType
  entity_id             Int
  external_id           String             @db.VarChar(120)
  external_secondary_id String?            @db.VarChar(120)
  metadata              Json?
  created_at            DateTime           @default(now())
  updated_at            DateTime           @updatedAt
  sistema_externo       SistemaExterno     @relation(fields: [sistema_externo_id], references: [id])

  @@unique([sistema_externo_id, entity_type, external_id])
  @@unique([sistema_externo_id, entity_type, entity_id])
  @@index([entity_type, entity_id])
}

model IntegrationEvent {
  id                 Int                    @id @default(autoincrement())
  sistema_externo_id Int
  event_type         String                 @db.VarChar(80)
  external_event_id  String?                @db.VarChar(120)
  idempotency_key    String                 @unique @db.VarChar(200)
  status             IntegrationEventStatus @default(PENDING)
  payload            Json
  result_payload     Json?
  error_message      String?
  processed_at       DateTime?
  created_at         DateTime               @default(now())
  updated_at         DateTime               @updatedAt
  sistema_externo    SistemaExterno         @relation(fields: [sistema_externo_id], references: [id])

  @@unique([sistema_externo_id, event_type, external_event_id])
  @@index([sistema_externo_id, status])
  @@index([created_at])
}

model ExternalSyncLog {
  id                 Int                @id @default(autoincrement())
  sistema_externo_id Int
  sync_type          String             @db.VarChar(80)
  status             ExternalSyncStatus @default(STARTED)
  request_payload    Json?
  response_summary   Json?
  error_message      String?
  started_at         DateTime           @default(now())
  finished_at        DateTime?
  created_at         DateTime           @default(now())
  updated_at         DateTime           @updatedAt
  sistema_externo    SistemaExterno     @relation(fields: [sistema_externo_id], references: [id])

  @@index([sistema_externo_id, status])
  @@index([started_at])
}

model ClienteContacto {
  id                    Int      @id @default(autoincrement())
  cliente_id            Int
  nombre                String   @db.VarChar(200)
  email                 String?  @db.VarChar(180)
  telefono              String?  @db.VarChar(30)
  cargo                 String?  @db.VarChar(120)
  es_principal          Boolean  @default(false)
  recibe_notificaciones Boolean  @default(false)
  recibe_comprobantes   Boolean  @default(false)
  whatsapp              Boolean  @default(false)
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt
  cliente               Cliente  @relation(fields: [cliente_id], references: [id], onDelete: Cascade)

  @@index([cliente_id])
}

model ClienteFacturacion {
  id                       Int      @id @default(autoincrement())
  cliente_id               Int
  rut_facturacion          String   @db.VarChar(20)
  razon_social_facturacion String   @db.VarChar(200)
  giro_facturacion         String?  @db.VarChar(200)
  direccion_facturacion    String?  @db.VarChar(255)
  comuna                   String?  @db.VarChar(120)
  ciudad                   String?  @db.VarChar(120)
  region                   String?  @db.VarChar(120)
  email_facturacion        String?  @db.VarChar(180)
  tipo_documento_preferido String?  @db.VarChar(80)
  requiere_oc              Boolean  @default(false)
  condicion_pago           String?  @db.VarChar(80)
  created_at               DateTime @default(now())
  updated_at               DateTime @updatedAt
  cliente                  Cliente  @relation(fields: [cliente_id], references: [id], onDelete: Cascade)

  @@unique([cliente_id, rut_facturacion])
  @@index([cliente_id])
}

model ClientImportBatch {
  id             Int                     @id @default(autoincrement())
  filename       String                  @db.VarChar(255)
  status         ImportBatchStatus       @default(PREVIEW_READY)
  total_clients  Int                     @default(0)
  ready_clients  Int                     @default(0)
  review_clients Int                     @default(0)
  error_clients  Int                     @default(0)
  created_by     Int
  created_at     DateTime                @default(now())
  confirmed_at   DateTime?
  creator        Usuario                 @relation(fields: [created_by], references: [id])
  client_items   ClientImportItem[]
  contract_items ContractImportItem[]
  cuota_items    InstallmentImportItem[]

  @@index([status])
  @@index([created_by])
}

model ClientImportItem {
  id                  Int               @id @default(autoincrement())
  batch_id            Int
  row_number          Int
  source_sheet        String            @db.VarChar(80)
  rut                 String?           @db.VarChar(20)
  nombre_razon_social String?           @db.VarChar(200)
  tipo_persona        String?           @db.VarChar(60)
  estado_cliente      String?           @db.VarChar(60)
  fecha_ingreso       DateTime?         @db.Date
  raw_data            Json
  normalized_data     Json?
  status              String            @default("READY") @db.VarChar(40)
  errors              Json?
  created_cliente_id  Int?
  created_at          DateTime          @default(now())
  batch               ClientImportBatch @relation(fields: [batch_id], references: [id], onDelete: Cascade)
  created_cliente     Cliente?          @relation(fields: [created_cliente_id], references: [id])

  @@index([batch_id, status])
  @@index([rut])
}

model ContractImportItem {
  id                  Int               @id @default(autoincrement())
  batch_id            Int
  row_number          Int
  cliente_rut         String?           @db.VarChar(20)
  servicio            String?           @db.VarChar(200)
  area                String?           @db.VarChar(120)
  monto_total         Decimal?          @db.Decimal(14, 2)
  cantidad_cuotas     Int?
  fecha_inicio        DateTime?         @db.Date
  estado_contrato     String?           @db.VarChar(60)
  raw_data            Json
  normalized_data     Json?
  status              String            @default("READY") @db.VarChar(40)
  errors              Json?
  created_contrato_id Int?
  created_at          DateTime          @default(now())
  batch               ClientImportBatch @relation(fields: [batch_id], references: [id], onDelete: Cascade)
  created_contrato    Contrato?         @relation(fields: [created_contrato_id], references: [id])

  @@index([batch_id, status])
  @@index([cliente_rut])
}

model InstallmentImportItem {
  id                Int               @id @default(autoincrement())
  batch_id          Int
  row_number        Int
  contrato_ref      String?           @db.VarChar(120)
  numero_cuota      Int?
  monto             Decimal?          @db.Decimal(14, 2)
  fecha_vencimiento DateTime?         @db.Date
  estado_cuota      String?           @db.VarChar(60)
  raw_data          Json
  normalized_data   Json?
  status            String            @default("READY") @db.VarChar(40)
  errors            Json?
  created_cuota_id  Int?
  created_at        DateTime          @default(now())
  batch             ClientImportBatch @relation(fields: [batch_id], references: [id], onDelete: Cascade)
  created_cuota     Cuota?            @relation(fields: [created_cuota_id], references: [id])

  @@index([batch_id, status])
  @@index([contrato_ref])
}

enum RolUsuario {
  ADMIN
  CONTADOR
  ANALISTA
  SOLO_LECTURA
}

enum TipoCliente {
  PERSONA
  EMPRESA
}

enum EstadoCliente {
  ACTIVO
  AL_DIA
  MOROSO
  FINALIZADO
  ANULADO
}

enum EstadoContrato {
  PENDING_INITIAL_PAYMENT
  ACTIVO
  PAGADO
  EN_MORA
  REPACTADO
  TERMINADO
  ANULADO
}

enum EstadoCuota {
  PENDIENTE
  PAGADA
  PARCIAL
  VENCIDA
  REPROGRAMADA
  REEMPLAZADA
  ANULADA
  CONDONADA
}

enum TipoModificacion {
  CAMBIO_FECHA
  REPACTACION
  CAMBIO_MONTO
  ANULACION
  CONDONACION
  EDICION_PAGO
}

enum ExternalEntityType {
  CLIENTE
  CONTRATO
  CASO_LEGAL
  CUOTA
  PAGO
}

enum IntegrationEventStatus {
  PENDING
  PROCESSED
  FAILED
}

enum ExternalSyncStatus {
  STARTED
  SUCCESS
  PARTIAL
  FAILED
}

enum EstadoPago {
  REGISTRADO
  CONFIRMADO
  RECHAZADO
  REVERSADO
}

enum CuotaWarningLevel {
  WARNING_10
  WARNING_20
  WARNING_30
}

model CuotaWarning {
  id                    Int               @id @default(autoincrement())
  cuota_id              Int
  contrato_id           Int
  cliente_id            Int
  level                 CuotaWarningLevel
  dias_atraso_at_send   Int
  channel               String            @db.VarChar(20)
  delivery_status       String            @db.VarChar(20)
  delivery_error        String?
  downstream_response   String?
  downstream_dispatched Boolean           @default(false)
  sent_at               DateTime?
  created_at            DateTime          @default(now())
  cliente               Cliente           @relation(fields: [cliente_id], references: [id])
  contrato              Contrato          @relation(fields: [contrato_id], references: [id])
  cuota                 Cuota             @relation(fields: [cuota_id], references: [id])

  @@unique([cuota_id, level])
  @@index([contrato_id])
  @@index([cliente_id])
}

enum ImportBatchStatus {
  PREVIEW_READY
  PROCESSING
  CONFIRMED
  FAILED
}

enum EstadoCompromiso {
  PENDIENTE
  CUMPLIDO
  INCUMPLIDO
}

enum TipoGestion {
  LLAMADA
  EMAIL
  VISITA
  CARTA
  WHATSAPP
}

enum ResultadoGestion {
  EXITOSO
  SIN_RESPUESTA
  PROMESA_PAGO
  RECHAZO
  OTRO
}

model CompromisoPago {
  id                 Int              @id @default(autoincrement())
  cliente_id         Int
  contrato_id        Int
  cuota_id           Int?
  fecha_compromiso   DateTime         @db.Date
  monto_comprometido Decimal          @db.Decimal(14, 2)
  estado             EstadoCompromiso @default(PENDIENTE)
  notas              String?
  usuario_id         Int
  created_at         DateTime         @default(now())
  updated_at         DateTime         @updatedAt
  cliente            Cliente          @relation(fields: [cliente_id], references: [id])
  contrato           Contrato         @relation(fields: [contrato_id], references: [id])
  cuota              Cuota?           @relation(fields: [cuota_id], references: [id])
  usuario            Usuario          @relation(fields: [usuario_id], references: [id])

  @@index([cliente_id])
  @@index([contrato_id])
  @@index([fecha_compromiso])
  @@index([estado])
}

model GestionCobranza {
  id                Int              @id @default(autoincrement())
  cliente_id        Int
  contrato_id       Int
  tipo              TipoGestion
  resultado         ResultadoGestion
  notas             String?
  fecha_gestion     DateTime         @db.Date
  seguimiento_fecha DateTime?        @db.Date
  usuario_id        Int
  created_at        DateTime         @default(now())
  cliente           Cliente          @relation(fields: [cliente_id], references: [id])
  contrato          Contrato         @relation(fields: [contrato_id], references: [id])
  usuario           Usuario          @relation(fields: [usuario_id], references: [id])

  @@index([cliente_id])
  @@index([contrato_id])
  @@index([fecha_gestion])
}

// ─────────────────────────────────────────────
// EMPRESA (multi-tenant root)
// ─────────────────────────────────────────────
model Empresa {
  id           Int      @id @default(autoincrement())
  nombre       String   @db.VarChar(200)
  rut          String   @unique @db.VarChar(20)
  razon_social String   @db.VarChar(200)
  giro         String?  @db.VarChar(200)
  direccion    String?  @db.VarChar(255)
  telefono     String?  @db.VarChar(30)
  email        String?  @db.VarChar(180)
  logo_url     String?  @db.VarChar(500)
  activa       Boolean  @default(true)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
}

// ─────────────────────────────────────────────
// TESORERÍA
// ─────────────────────────────────────────────
model Banco {
  id           Int              @id @default(autoincrement())
  empresa_id   Int?
  nombre       String           @db.VarChar(120)
  codigo_banco String?          @db.VarChar(20)
  activo       Boolean          @default(true)
  created_at   DateTime         @default(now())
  updated_at   DateTime         @updatedAt
  cuentas      CuentaBancaria[]

  @@index([empresa_id])
}

model CuentaBancaria {
  id               Int                    @id @default(autoincrement())
  empresa_id       Int?
  banco_id         Int
  nombre           String                 @db.VarChar(120)
  numero_cuenta    String                 @db.VarChar(40)
  tipo_cuenta      TipoCuentaBancaria
  moneda           String                 @default("CLP") @db.VarChar(10)
  saldo_inicial    Decimal                @default(0) @db.Decimal(14, 2)
  activa           Boolean                @default(true)
  cuenta_principal Boolean                @default(false)
  created_at       DateTime               @default(now())
  updated_at       DateTime               @updatedAt
  banco            Banco                  @relation(fields: [banco_id], references: [id])
  movimientos      MovimientoTesoreria[]
  egresos          EgresoTesoreria[]
  conciliaciones   ConciliacionBancaria[]

  @@index([empresa_id])
}

model MovimientoTesoreria {
  id               Int                     @id @default(autoincrement())
  empresa_id       Int?
  cuenta_id        Int
  tipo             TipoMovimientoTesoreria
  categoria        String?                 @db.VarChar(120)
  descripcion      String                  @db.VarChar(300)
  monto            Decimal                 @db.Decimal(14, 2)
  fecha_movimiento DateTime                @db.Date
  referencia       String?                 @db.VarChar(120)
  comprobante_url  String?                 @db.VarChar(500)
  conciliado       Boolean                 @default(false)
  pago_id          Int?
  created_at       DateTime                @default(now())
  updated_at       DateTime                @updatedAt
  cuenta           CuentaBancaria          @relation(fields: [cuenta_id], references: [id])

  @@index([empresa_id])
  @@index([cuenta_id])
  @@index([fecha_movimiento])
}

model EgresoTesoreria {
  id                Int            @id @default(autoincrement())
  empresa_id        Int?
  cuenta_id         Int
  proveedor_id      Int?
  categoria         String         @db.VarChar(120)
  descripcion       String         @db.VarChar(300)
  monto             Decimal        @db.Decimal(14, 2)
  fecha_egreso      DateTime       @db.Date
  fecha_vencimiento DateTime?      @db.Date
  estado            EstadoEgreso   @default(PENDIENTE)
  referencia        String?        @db.VarChar(120)
  comprobante_url   String?        @db.VarChar(500)
  recurrente        Boolean        @default(false)
  created_at        DateTime       @default(now())
  updated_at        DateTime       @updatedAt
  cuenta            CuentaBancaria @relation(fields: [cuenta_id], references: [id])
  proveedor         Proveedor?     @relation(fields: [proveedor_id], references: [id])

  @@index([empresa_id])
  @@index([cuenta_id])
  @@index([estado])
}

model ConciliacionBancaria {
  id            Int                @id @default(autoincrement())
  empresa_id    Int?
  cuenta_id     Int
  periodo       String             @db.VarChar(7)
  estado        EstadoConciliacion @default(EN_PROCESO)
  saldo_banco   Decimal            @db.Decimal(14, 2)
  saldo_sistema Decimal            @db.Decimal(14, 2)
  diferencia    Decimal            @db.Decimal(14, 2)
  created_at    DateTime           @default(now())
  updated_at    DateTime           @updatedAt
  cuenta        CuentaBancaria     @relation(fields: [cuenta_id], references: [id])
  items         ItemConciliacion[]

  @@index([empresa_id])
  @@index([cuenta_id, periodo])
}

model ItemConciliacion {
  id                    Int                  @id @default(autoincrement())
  conciliacion_id       Int
  fecha_movimiento      DateTime             @db.Date
  glosa                 String               @db.VarChar(300)
  cargo                 Decimal?             @db.Decimal(14, 2)
  abono                 Decimal?             @db.Decimal(14, 2)
  conciliado            Boolean              @default(false)
  movimiento_sistema_id Int?
  created_at            DateTime             @default(now())
  conciliacion          ConciliacionBancaria @relation(fields: [conciliacion_id], references: [id], onDelete: Cascade)

  @@index([conciliacion_id])
}

// ─────────────────────────────────────────────
// CAJA CHICA
// ─────────────────────────────────────────────
model FondoCajaChica {
  id              Int                  @id @default(autoincrement())
  empresa_id      Int?
  nombre          String               @db.VarChar(120)
  monto_asignado  Decimal              @db.Decimal(14, 2)
  saldo_actual    Decimal              @db.Decimal(14, 2)
  responsable_id  Int
  activo          Boolean              @default(true)
  monto_max_gasto Decimal              @db.Decimal(14, 2)
  created_at      DateTime             @default(now())
  updated_at      DateTime             @updatedAt
  responsable     Usuario              @relation("FondoResponsable", fields: [responsable_id], references: [id])
  gastos          GastoCajaChica[]
  rendiciones     RendicionCajaChica[]

  @@index([empresa_id])
}

model GastoCajaChica {
  id              Int                 @id @default(autoincrement())
  fondo_id        Int
  empresa_id      Int?
  categoria       String              @db.VarChar(120)
  descripcion     String              @db.VarChar(300)
  monto           Decimal             @db.Decimal(14, 2)
  fecha_gasto     DateTime            @db.Date
  responsable_id  Int
  comprobante_url String?             @db.VarChar(500)
  rendicion_id    Int?
  created_at      DateTime            @default(now())
  fondo           FondoCajaChica      @relation(fields: [fondo_id], references: [id])
  responsable     Usuario             @relation("GastoCajaResponsable", fields: [responsable_id], references: [id])
  rendicion       RendicionCajaChica? @relation(fields: [rendicion_id], references: [id])

  @@index([fondo_id])
  @@index([rendicion_id])
}

model RendicionCajaChica {
  id            Int                  @id @default(autoincrement())
  fondo_id      Int
  empresa_id    Int?
  periodo       String               @db.VarChar(20)
  total_gastos  Decimal              @db.Decimal(14, 2)
  estado        EstadoRendicion      @default(BORRADOR)
  aprobado_por  Int?
  observaciones String?
  created_at    DateTime             @default(now())
  updated_at    DateTime             @updatedAt
  fondo         FondoCajaChica       @relation(fields: [fondo_id], references: [id])
  aprobador     Usuario?             @relation("RendicionesAprobadas", fields: [aprobado_por], references: [id])
  gastos        GastoCajaChica[]
  reposicion    ReposicionCajaChica?

  @@index([fondo_id])
}

model ReposicionCajaChica {
  id           Int                @id @default(autoincrement())
  rendicion_id Int                @unique
  empresa_id   Int?
  monto        Decimal            @db.Decimal(14, 2)
  estado       EstadoReposicion   @default(PENDIENTE)
  aprobado_por Int?
  created_at   DateTime           @default(now())
  updated_at   DateTime           @updatedAt
  rendicion    RendicionCajaChica @relation(fields: [rendicion_id], references: [id])
  aprobador    Usuario?           @relation("ReposicionesAprobadas", fields: [aprobado_por], references: [id])
}

// ─────────────────────────────────────────────
// VENTAS
// ─────────────────────────────────────────────
model Servicio {
  id            Int                @id @default(autoincrement())
  empresa_id    Int?
  nombre        String             @db.VarChar(200)
  descripcion   String?
  precio_ref    Decimal?           @db.Decimal(14, 2)
  tipo_impuesto String             @default("EXENTO") @db.VarChar(40)
  activo        Boolean            @default(true)
  created_at    DateTime           @default(now())
  updated_at    DateTime           @updatedAt
  documentos    DocumentoVenta[]
  reglas        ReglaFacturacion[]

  @@index([empresa_id])
}

model DocumentoVenta {
  id                Int                   @id @default(autoincrement())
  empresa_id        Int?
  tipo              TipoDocumentoVenta
  numero            Int?
  cliente_id        Int?
  razon_social      String                @db.VarChar(200)
  rut_receptor      String?               @db.VarChar(20)
  fecha_emision     DateTime              @db.Date
  fecha_vencimiento DateTime?             @db.Date
  monto_neto        Decimal               @default(0) @db.Decimal(14, 2)
  iva               Decimal               @default(0) @db.Decimal(14, 2)
  monto_total       Decimal               @db.Decimal(14, 2)
  estado            EstadoDocVenta        @default(EMITIDO)
  estado_sii        String?               @db.VarChar(40)
  servicio_id       Int?
  observaciones     String?
  regla_id          Int?
  created_at        DateTime              @default(now())
  updated_at        DateTime              @updatedAt
  cliente           Cliente?              @relation(fields: [cliente_id], references: [id])
  servicio          Servicio?             @relation(fields: [servicio_id], references: [id])
  lineas            LineaDocumentoVenta[]
  notas_credito     NotaCredito[]

  @@index([empresa_id])
  @@index([cliente_id])
  @@index([tipo, estado])
}

model LineaDocumentoVenta {
  id              Int            @id @default(autoincrement())
  documento_id    Int
  descripcion     String         @db.VarChar(300)
  cantidad        Decimal        @default(1) @db.Decimal(10, 3)
  precio_unitario Decimal        @db.Decimal(14, 2)
  descuento       Decimal        @default(0) @db.Decimal(14, 2)
  subtotal        Decimal        @db.Decimal(14, 2)
  created_at      DateTime       @default(now())
  documento       DocumentoVenta @relation(fields: [documento_id], references: [id], onDelete: Cascade)

  @@index([documento_id])
}

model NotaCredito {
  id                  Int            @id @default(autoincrement())
  empresa_id          Int?
  documento_origen_id Int
  numero              Int?
  monto               Decimal        @db.Decimal(14, 2)
  motivo              String         @db.VarChar(300)
  fecha_emision       DateTime       @db.Date
  estado              EstadoDocVenta @default(EMITIDO)
  created_at          DateTime       @default(now())
  documento_origen    DocumentoVenta @relation(fields: [documento_origen_id], references: [id])

  @@index([documento_origen_id])
}

model ReglaFacturacion {
  id             Int       @id @default(autoincrement())
  empresa_id     Int?
  cliente_id     Int
  servicio_id    Int?
  nombre         String    @db.VarChar(200)
  periodicidad   String    @db.VarChar(40)
  dia_emision    Int
  monto          Decimal   @db.Decimal(14, 2)
  activa         Boolean   @default(true)
  tipo_ejecucion String    @default("MANUAL") @db.VarChar(20)
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt
  cliente        Cliente   @relation(fields: [cliente_id], references: [id])
  servicio       Servicio? @relation(fields: [servicio_id], references: [id])

  @@index([empresa_id])
  @@index([cliente_id])
}

// ─────────────────────────────────────────────
// COMPRAS
// ─────────────────────────────────────────────
model Proveedor {
  id                Int                 @id @default(autoincrement())
  empresa_id        Int?
  rut               String              @db.VarChar(20)
  nombre            String              @db.VarChar(200)
  razon_social      String?             @db.VarChar(200)
  giro              String?             @db.VarChar(200)
  direccion         String?             @db.VarChar(255)
  telefono          String?             @db.VarChar(30)
  email             String?             @db.VarChar(180)
  banco             String?             @db.VarChar(120)
  numero_cuenta     String?             @db.VarChar(40)
  tipo_cuenta_pago  String?             @db.VarChar(40)
  categoria         String?             @db.VarChar(120)
  activo            Boolean             @default(true)
  created_at        DateTime            @default(now())
  updated_at        DateTime            @updatedAt
  gastos            GastoCompra[]
  documentos        DocumentoCompra[]
  honorarios        HonorarioRecibido[]
  egresos           EgresoTesoreria[]
  cuentas_por_pagar CuentaPorPagar[]

  @@unique([empresa_id, rut])
  @@index([empresa_id])
}

model GastoCompra {
  id              Int             @id @default(autoincrement())
  empresa_id      Int?
  proveedor_id    Int?
  categoria       String          @db.VarChar(120)
  descripcion     String          @db.VarChar(300)
  monto_neto      Decimal         @db.Decimal(14, 2)
  iva             Decimal         @default(0) @db.Decimal(14, 2)
  monto_total     Decimal         @db.Decimal(14, 2)
  fecha_gasto     DateTime        @db.Date
  estado_pago     EstadoPagoGasto @default(PENDIENTE)
  comprobante_url String?         @db.VarChar(500)
  aprobado        Boolean         @default(false)
  cuenta_contable String?         @db.VarChar(40)
  created_at      DateTime        @default(now())
  updated_at      DateTime        @updatedAt
  proveedor       Proveedor?      @relation(fields: [proveedor_id], references: [id])

  @@index([empresa_id])
  @@index([proveedor_id])
  @@index([estado_pago])
}

model DocumentoCompra {
  id                Int                    @id @default(autoincrement())
  empresa_id        Int?
  proveedor_id      Int
  tipo              TipoDocumentoCompra
  numero            String?                @db.VarChar(40)
  fecha_emision     DateTime               @db.Date
  fecha_vencimiento DateTime?              @db.Date
  monto_neto        Decimal                @db.Decimal(14, 2)
  iva               Decimal                @default(0) @db.Decimal(14, 2)
  monto_total       Decimal                @db.Decimal(14, 2)
  estado            EstadoDocCompra        @default(RECIBIDO)
  reclamado         Boolean                @default(false)
  motivo_reclamo    String?
  created_at        DateTime               @default(now())
  updated_at        DateTime               @updatedAt
  proveedor         Proveedor              @relation(fields: [proveedor_id], references: [id])
  lineas            LineaDocumentoCompra[]
  cuenta_por_pagar  CuentaPorPagar?

  @@index([empresa_id])
  @@index([proveedor_id])
  @@index([estado])
}

model LineaDocumentoCompra {
  id              Int             @id @default(autoincrement())
  documento_id    Int
  descripcion     String          @db.VarChar(300)
  cantidad        Decimal         @default(1) @db.Decimal(10, 3)
  precio_unitario Decimal         @db.Decimal(14, 2)
  subtotal        Decimal         @db.Decimal(14, 2)
  created_at      DateTime        @default(now())
  documento       DocumentoCompra @relation(fields: [documento_id], references: [id], onDelete: Cascade)

  @@index([documento_id])
}

model HonorarioRecibido {
  id                 Int       @id @default(autoincrement())
  empresa_id         Int?
  proveedor_id       Int
  monto_bruto        Decimal   @db.Decimal(14, 2)
  tasa_retencion     Decimal   @default(0.1075) @db.Decimal(5, 4)
  monto_retencion    Decimal   @db.Decimal(14, 2)
  monto_neto         Decimal   @db.Decimal(14, 2)
  fecha_emision      DateTime  @db.Date
  periodo_tributario String?   @db.VarChar(7)
  pagado             Boolean   @default(false)
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt
  proveedor          Proveedor @relation(fields: [proveedor_id], references: [id])

  @@index([empresa_id])
  @@index([proveedor_id])
}

model CuentaPorPagar {
  id                Int              @id @default(autoincrement())
  empresa_id        Int?
  proveedor_id      Int
  documento_id      Int?             @unique
  monto             Decimal          @db.Decimal(14, 2)
  fecha_vencimiento DateTime         @db.Date
  estado            EstadoCxP        @default(PENDIENTE)
  fecha_pago        DateTime?        @db.Date
  created_at        DateTime         @default(now())
  updated_at        DateTime         @updatedAt
  proveedor         Proveedor        @relation(fields: [proveedor_id], references: [id])
  documento         DocumentoCompra? @relation(fields: [documento_id], references: [id])

  @@index([empresa_id])
  @@index([proveedor_id])
  @@index([estado, fecha_vencimiento])
}

// ─────────────────────────────────────────────
// CONTABILIDAD
// ─────────────────────────────────────────────
model CuentaContable {
  id                 Int                @id @default(autoincrement())
  empresa_id         Int?
  codigo             String             @db.VarChar(20)
  nombre             String             @db.VarChar(200)
  tipo               TipoCuentaContable
  naturaleza         NaturalezaCuenta
  nivel              Int                @default(1)
  cuenta_padre_id    Int?
  acepta_movimientos Boolean            @default(true)
  activa             Boolean            @default(true)
  created_at         DateTime           @default(now())
  updated_at         DateTime           @updatedAt
  cuenta_padre       CuentaContable?    @relation("JerarquiaCuentas", fields: [cuenta_padre_id], references: [id])
  cuentas_hijas      CuentaContable[]   @relation("JerarquiaCuentas")
  partidas           PartidaContable[]

  @@unique([empresa_id, codigo])
  @@index([empresa_id])
  @@index([tipo])
}

model TipoComprobanteContable {
  id               Int                   @id @default(autoincrement())
  empresa_id       Int?
  nombre           String                @db.VarChar(120)
  descripcion      String?
  prefijo          String?               @db.VarChar(10)
  siguiente_numero Int                   @default(1)
  activo           Boolean               @default(true)
  created_at       DateTime              @default(now())
  updated_at       DateTime              @updatedAt
  comprobantes     ComprobanteContable[]

  @@index([empresa_id])
}

model ComprobanteContable {
  id                Int                     @id @default(autoincrement())
  empresa_id        Int?
  tipo_id           Int
  numero            Int
  fecha_comprobante DateTime                @db.Date
  descripcion       String                  @db.VarChar(300)
  estado            EstadoComprobante       @default(BORRADOR)
  total_debe        Decimal                 @db.Decimal(14, 2)
  total_haber       Decimal                 @db.Decimal(14, 2)
  usuario_id        Int?
  aprobado_por      Int?
  created_at        DateTime                @default(now())
  updated_at        DateTime                @updatedAt
  tipo              TipoComprobanteContable @relation(fields: [tipo_id], references: [id])
  usuario           Usuario?                @relation("ComprobanteUsuario", fields: [usuario_id], references: [id])
  aprobador         Usuario?                @relation("ComprobanteAprobador", fields: [aprobado_por], references: [id])
  partidas          PartidaContable[]

  @@index([empresa_id])
  @@index([tipo_id, numero])
  @@index([estado])
  @@index([fecha_comprobante])
}

model PartidaContable {
  id             Int                    @id @default(autoincrement())
  comprobante_id Int
  cuenta_id      Int
  tipo           TipoMovimientoContable
  monto          Decimal                @db.Decimal(14, 2)
  glosa          String?                @db.VarChar(300)
  created_at     DateTime               @default(now())
  comprobante    ComprobanteContable    @relation(fields: [comprobante_id], references: [id], onDelete: Cascade)
  cuenta         CuentaContable         @relation(fields: [cuenta_id], references: [id])

  @@index([comprobante_id])
  @@index([cuenta_id])
}

model CierreContable {
  id            Int        @id @default(autoincrement())
  empresa_id    Int?
  tipo          TipoCierre
  periodo       String     @db.VarChar(7)
  fecha_cierre  DateTime   @db.Date
  usuario_id    Int?
  observaciones String?
  created_at    DateTime   @default(now())
  usuario       Usuario?   @relation(fields: [usuario_id], references: [id])

  @@unique([empresa_id, tipo, periodo])
  @@index([empresa_id])
}

// ─────────────────────────────────────────────
// CONFIGURACIÓN
// ─────────────────────────────────────────────
model ConfigEmpresa {
  id                Int      @id @default(autoincrement())
  empresa_id        Int?     @unique
  razon_social      String?  @db.VarChar(200)
  rut               String?  @db.VarChar(20)
  giro              String?  @db.VarChar(200)
  direccion         String?  @db.VarChar(255)
  telefono          String?  @db.VarChar(30)
  email             String?  @db.VarChar(180)
  logo_url          String?  @db.VarChar(500)
  anio_fiscal       Int?
  moneda_base       String   @default("CLP") @db.VarChar(10)
  zona_horaria      String   @default("America/Santiago") @db.VarChar(60)
  dias_gracia_mora  Int      @default(0)
  tasa_interes_mora Decimal  @default(0) @db.Decimal(5, 4)
  formato_fecha     String   @default("dd/MM/yyyy") @db.VarChar(20)
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt
}

model Impuesto {
  id         Int      @id @default(autoincrement())
  empresa_id Int?
  nombre     String   @db.VarChar(120)
  tasa       Decimal  @db.Decimal(5, 4)
  tipo       String   @db.VarChar(40)
  activo     Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([empresa_id])
}

model CondicionPago {
  id          Int      @id @default(autoincrement())
  empresa_id  Int?
  nombre      String   @db.VarChar(120)
  dias_plazo  Int      @default(0)
  descripcion String?
  activa      Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([empresa_id])
}

model TipoDocumentoTributario {
  id              Int      @id @default(autoincrement())
  empresa_id      Int?
  nombre          String   @db.VarChar(120)
  codigo          String   @db.VarChar(20)
  folio_inicial   Int      @default(1)
  siguiente_folio Int      @default(1)
  cuenta_contable String?  @db.VarChar(40)
  activo          Boolean  @default(true)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@index([empresa_id])
}

model CategoriaGasto {
  id              Int      @id @default(autoincrement())
  empresa_id      Int?
  nombre          String   @db.VarChar(120)
  cuenta_contable String?  @db.VarChar(40)
  activa          Boolean  @default(true)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@index([empresa_id])
}

model TipoMovimientoConfig {
  id              Int      @id @default(autoincrement())
  empresa_id      Int?
  nombre          String   @db.VarChar(120)
  naturaleza      String   @db.VarChar(10)
  cuenta_contable String?  @db.VarChar(40)
  recurrente      Boolean  @default(false)
  activo          Boolean  @default(true)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@index([empresa_id])
}

// ─────────────────────────────────────────────
