# ── Base de datos (PostgreSQL — DigitalOcean managed) ─────────────────────────
# DATABASE_URL: URL de pool (pgBouncer) — usada por Next.js en runtime
# DIRECT_URL:   conexión directa — requerida por Prisma para migraciones
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?pgbouncer=true&connection_limit=10&sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# ── App ────────────────────────────────────────────────────────────────────────
APP_URL="http://localhost:3000"
JWT_SECRET="genera-un-secreto-aleatorio-de-32-chars-minimo"

# ── Cron / Jobs internos ───────────────────────────────────────────────────────
CRON_SECRET="secreto-para-autenticar-llamadas-al-cron"

# ── API interna (entre servicios) ─────────────────────────────────────────────
INTERNAL_API_KEY="clave-para-endpoints-internos"
INTERNAL_BEARER_TOKEN="bearer-para-endpoints-internos"

# ── AT-Informa ─────────────────────────────────────────────────────────────────
AT_INFORMA_API_URL="https://api.at-informa.cl"
AT_INFORMA_BASE_URL="https://api.at-informa.cl"
AT_INFORMA_API_KEY="tu-api-key-at-informa"
AT_INFORMA_TOKEN="tu-token-at-informa"

# ── Kommo CRM ─────────────────────────────────────────────────────────────────
CRM_BASE_URL="https://tu-cuenta.kommo.com"
CRM_INTERNAL_API_KEY="clave-interna-crm"

# ── PagaCuotas ────────────────────────────────────────────────────────────────
PAGACUOTAS_API_URL="http://localhost:4000"
PAGACUOTAS_PORTAL_URL="http://localhost:3004"
PAGACUOTAS_INTERNAL_API_KEY="secreto-pagacuotas-interno"
PAGACUOTAS_INTERNAL_BEARER_TOKEN="bearer-pagacuotas-interno"
PAGACUOTAS_CRM_API_KEY="clave-crm-pagacuotas"

# ── Hive Service (notificaciones de morosidad) ────────────────────────────────
HIVE_SERVICE_URL="http://localhost:5000"
HIVE_SERVICE_API_KEY="secreto-hive-service"
HIVE_SERVICE_INTEGRATION_API_KEY="secreto-integracion-hive-service"
