# ─────────────────────────────────────────────
# BASE DE DATOS — PostgreSQL (Supabase)
# ─────────────────────────────────────────────
# DATABASE_URL → PgBouncer pool (Transaction mode, puerto 6543) — para queries en producción
# DIRECT_URL   → conexión directa (puerto 5432) — solo para "prisma migrate"
#
# Obtener desde: Supabase → Settings → Database → Connection string
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# ─────────────────────────────────────────────
# NEXTAUTH v5
# ─────────────────────────────────────────────
# Generar con: openssl rand -base64 32
AUTH_SECRET="REEMPLAZAR_CON_SECRET_DE_256_BITS_MINIMO"
NEXTAUTH_URL="http://localhost:3000"

# ─────────────────────────────────────────────
# META WHATSAPP BUSINESS API
# ─────────────────────────────────────────────
META_WHATSAPP_TOKEN="REEMPLAZAR_CON_TOKEN_DE_META"
META_WHATSAPP_PHONE_ID="REEMPLAZAR_CON_PHONE_ID"
META_WHATSAPP_VERIFY_TOKEN="REEMPLAZAR_CON_VERIFY_TOKEN"

# ─────────────────────────────────────────────
# EMAIL — Resend
# ─────────────────────────────────────────────
RESEND_API_KEY="REEMPLAZAR_CON_API_KEY_RESEND"
RESEND_FROM_EMAIL="AT Informa <noreply@atinforma.cl>"

# ─────────────────────────────────────────────
# URL PÚBLICA DE LA APP
# ─────────────────────────────────────────────
APP_URL="https://atinforma.cl"

# ─────────────────────────────────────────────
# GOOGLE CALENDAR — OAuth por usuario
# Callback autorizado en Google Cloud:
# http://localhost:3000/api/integrations/google-calendar/callback
# https://atinforma.cl/api/integrations/google-calendar/callback
# ─────────────────────────────────────────────
GOOGLE_CALENDAR_CLIENT_ID="REEMPLAZAR_CON_CLIENT_ID"
GOOGLE_CALENDAR_CLIENT_SECRET="REEMPLAZAR_CON_CLIENT_SECRET"
# Opcional: si no se configura, se usa AUTH_SECRET.
GOOGLE_CALENDAR_TOKEN_SECRET="REEMPLAZAR_CON_SECRET_DE_256_BITS_MINIMO"

# ─────────────────────────────────────────────
# SUPABASE STORAGE (documentos adjuntos)
# ─────────────────────────────────────────────
SUPABASE_URL="REEMPLAZAR_CON_URL_SUPABASE"
SUPABASE_ANON_KEY="REEMPLAZAR_CON_ANON_KEY"
SUPABASE_SERVICE_KEY="REEMPLAZAR_CON_SERVICE_KEY"

# ─────────────────────────────────────────────
# IA — OpenAI
# ─────────────────────────────────────────────
OPENAI_API_KEY="REEMPLAZAR_CON_API_KEY_OPENAI"

# ─────────────────────────────────────────────
# CRON JOBS — protección de endpoints /api/cron/*
# Generar con: openssl rand -hex 32
# ─────────────────────────────────────────────
CRON_SECRET="REEMPLAZAR_CON_SECRET_ALEATORIO"

# ─────────────────────────────────────────────
# API EXTERNA — Sistema de contabilidad
# ─────────────────────────────────────────────
# Clave para autenticar el sistema de contabilidad del contador.
# Usada por los endpoints /api/v1/* (clientes, cobranza, pagos).
# Generar con: openssl rand -hex 32
# El sistema contable debe enviar: Authorization: Bearer <clave>
# ─────────────────────────────────────────────
EXTERNAL_API_KEY="REEMPLAZAR_CON_CLAVE_SEGURA_32_BYTES"

PAGACUOTAS_API_URL=http://localhost:4000
PAGACUOTAS_CRM_API_KEY=f1e2d3c4b5a697887766554433221100ffeeddccbbaa99887766554433221100
