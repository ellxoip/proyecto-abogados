  "private": true,
  "scripts": {
    "dev": "node scripts/dev.js",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "ts-node --compiler-options \"{\\\"module\\\":\\\"CommonJS\\\"}\" prisma/seed.ts",
    "db:rls": "psql \"$DIRECT_URL\" -v ON_ERROR_STOP=1 -f prisma/sql/rls.sql",
    "db:studio": "prisma studio",
    "test": "node scripts/run-tests.js run",
    "test:watch": "node scripts/run-tests.js watch",
    "test:postgres-restore": "node scripts/swap-schema.js postgres && prisma generate",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
