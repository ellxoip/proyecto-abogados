// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model CrmClientProfile {
  id                   String   @id @default(uuid())
  identifier           String   @unique // RUT normalizado
  cliente_contable_id  String?           // hidratado en el primer auto-login
  crm_lead_id          String?  @unique
  // Contacto
  nombre               String
  telefono             String?
  email                String?
  rut                  String
  rut_empresa          String?
  empresa              String?
  ciudad               String?
  // Expediente
  area                 String?
  prioridad            String?
  vendedor             String?
  agendadora           String?
  fuente               String?
  // Honorarios snapshot (autoritativo en SIS.CONTABLE)
  total_snapshot       Decimal?
  cuota_inicial_snap   Decimal?
  num_cuotas           Int?
  monto_cuota_snap     Decimal?
  // Notas
  descripcion          String?
  notas_internas       String?
  // Magic link permanente
  magic_token          String   @unique
  magic_token_revoked  Boolean  @default(false)
  last_login_at        DateTime?
  // Timestamps
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  @@index([magic_token])
  @@index([crm_lead_id])
}

model PaymentPortalSession {
  id                  String   @id @default(uuid())
  identifier          String   // RUT, email, etc.
  cliente_contable_id String
  token               String   @unique
  ip_address          String?
  user_agent          String?
  expires_at          DateTime
  created_at          DateTime @default(now())

  @@index([identifier])
  @@index([expires_at])
  @@index([cliente_contable_id])
}

model PaymentAttempt {
  id                      String   @id @default(uuid())
  external_attempt_id     String   @unique // pc_attempt_...
  cliente_identifier      String?  // RUT/email/id used by the client in the portal
  cliente_contable_id     String
  contrato_contable_id    String
  cuota_ids_json          String   // JSON string array of installment IDs
  provider                String   // e.g., mercadopago
  provider_transaction_id String?  @unique
  amount                  Decimal
  currency                String   @default("CLP")
  method                  String?  // tarjeta, transferencia, etc.
  status                  String   // iniciado, pendiente, autorizado, confirmado, rechazado, expirado, error, reversado
  // SIS.CONTABLE sync
  sis_contable_sync_status String  @default("pending") // pending, synced, failed
  sis_contable_error       String?
  sis_contable_retry_count Int     @default(0)
  // Provider payloads
  request_payload_json    String?  // Raw request to provider
  response_payload_json   String?  // Raw response from provider
  provider_payload_json   String?  // Webhook payload
  // Validation from SIS.CONTABLE
  validation_status       String?  // APPROVED_TO_PAY, REJECTED
  validation_expires_at   DateTime?
  // Timestamps
  created_at              DateTime @default(now())
  updated_at              DateTime @updatedAt
  payments                Payment[]

  @@index([cliente_identifier])
  @@index([cliente_contable_id])
  @@index([contrato_contable_id])
  @@index([status])
  @@index([sis_contable_sync_status])
  @@index([created_at])
}

model Payment {
  id                        String   @id @default(uuid())
  external_payment_id       String   @unique // pc_payment_...
  payment_attempt_id        String
  attempt                   PaymentAttempt @relation(fields: [payment_attempt_id], references: [id])
  cliente_contable_id       String
  contrato_contable_id      String
  provider                  String
  provider_transaction_id   String?
  transaction_number        String?
  amount                    Decimal
  method                    String?
  status                    String   // confirmado, rechazado, reversado, anulado
  paid_at                   DateTime?
  receipt_url               String?
  billing_status            String   @default("not_required") // not_required, pending, submitted, accepted, rejected, failed
  billing_document_id       String?  @unique
  billing_document          BillingDocument? @relation("PaymentBillingDocument", fields: [billing_document_id], references: [id])
  // SIS.CONTABLE sync
  sis_contable_sync_status  String   @default("pending")
  sis_contable_error        String?
  sis_contable_retry_count  Int      @default(0)
  // CRM sync
  crm_sync_status           String   @default("pending") // pending, synced, failed, skipped
  crm_sync_error            String?
  crm_retry_count           Int      @default(0)
  // Provider raw data
  raw_provider_payload_json String?
  // Timestamps
  created_at                DateTime @default(now())
  updated_at                DateTime @updatedAt
  reversals                 PaymentReversal[]
  billing_documents         BillingDocument[] @relation("PaymentBillingDocuments")

  @@index([payment_attempt_id])
  @@index([cliente_contable_id])
  @@index([contrato_contable_id])
  @@index([status])
  @@index([sis_contable_sync_status])
  @@index([crm_sync_status])
  @@index([billing_status])
  @@index([created_at])
}

model BillingDocument {
  id                     String   @id @default(uuid())
  external_billing_id    String?  @unique
  payment_id             String
  payment                Payment  @relation("PaymentBillingDocuments", fields: [payment_id], references: [id])
  selected_for_payment   Payment? @relation("PaymentBillingDocument")
  provider               String
  document_type          String
  sii_type               String
  folio                  String?
  track_id               String?
  status                 String   @default("pending") // pending, submitted, accepted, rejected, cancelled, failed
  recipient_rut          String
  recipient_name         String
  recipient_email        String?
  net_amount             Decimal
  tax_amount             Decimal
  total_amount           Decimal
  pdf_url                String?
  xml_url                String?
  request_payload_json   String?
  response_payload_json  String?
  provider_payload_json  String?
  error_message          String?
  retry_count            Int      @default(0)
  issued_at              DateTime?
  accepted_at            DateTime?
  created_at             DateTime @default(now())
  updated_at             DateTime @updatedAt

  @@index([payment_id])
  @@index([provider])
  @@index([document_type])
  @@index([sii_type])
  @@index([status])
  @@index([created_at])
}

model PaymentReversal {
  id                        String   @id @default(uuid())
  external_reversal_id      String   @unique // pc_reversal_...
  external_payment_id       String
  external_attempt_id       String
  payment_id                String
  payment                   Payment  @relation(fields: [payment_id], references: [id])
  cliente_contable_id       String
  contrato_contable_id      String
  provider                  String
  cuota_ids_json            String
  amount_reversed           Decimal
  reason                    String?
  provider_reversal_code    String?
  // SIS.CONTABLE sync
  sis_contable_sync_status  String   @default("pending")
  sis_contable_error        String?
  // CRM sync
  crm_sync_status           String   @default("pending")
  crm_sync_error            String?
  // Timestamps
  reversed_at               DateTime
  created_at                DateTime @default(now())
  updated_at                DateTime @updatedAt

  @@index([external_payment_id])
  @@index([external_attempt_id])
  @@index([payment_id])
  @@index([sis_contable_sync_status])
  @@index([crm_sync_status])
  @@index([created_at])
}

model IntegrationLog {
  id                    String   @id @default(uuid())
  direction             String   // inbound, outbound
  system                String   // sis_contable, crm, payment_provider
  event_type            String
  endpoint              String?
  http_method           String?
  request_payload_json  String?
  response_payload_json String?
  status                Int?
  duration_ms           Int?
  error_message         String?
  created_at            DateTime @default(now())

  @@index([system])
  @@index([event_type])
  @@index([direction])
  @@index([status])
  @@index([created_at])
}

model IntegrationOutbox {
  id                   String   @id @default(uuid())
  event_type           String
  aggregate_type       String
  aggregate_id         String
  idempotency_key      String   @unique
  payload_json         String
  status               String   @default("pending") // pending, processing, published, failed
  retry_count          Int      @default(0)
  last_error           String?
  next_attempt_at      DateTime?
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  @@index([status, next_attempt_at])
  @@index([aggregate_type, aggregate_id])
  @@index([event_type])
  @@index([created_at])
}

model DeadLetterQueue {
  id                   String   @id @default(uuid())
  source               String
  event_type           String
  aggregate_id         String?
  payload_json         String?
  error_message        String
  retry_count          Int      @default(0)
  status               String   @default("open") // open, resolved, ignored
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  @@index([status])
  @@index([source])
  @@index([event_type])
  @@index([created_at])
}

model ReconciliationRun {
  id                   String   @id @default(uuid())
  started_at           DateTime @default(now())
  finished_at          DateTime?
  status               String   @default("running") // running, completed, failed
  payments_checked     Int      @default(0)
  sis_retried          Int      @default(0)
  crm_retried          Int      @default(0)
  errors_count         Int      @default(0)
  result_json          String?

  @@index([status])
  @@index([started_at])
}

model SupportTicket {
  id                   String   @id @default(uuid())
  ticket_number        String   @unique
  requester_identifier String
  requester_name       String?
  requester_email      String?
  requester_phone      String?
  subject              String
  category             String
  priority             String   @default("normal") // low, normal, high, urgent
  message              String
  status               String   @default("open") // open, in_progress, answered, closed
  admin_response       String?
  assigned_to          String?
  source               String   @default("client_portal")
  notification_status  String   @default("pending") // pending, sent, skipped, failed
  notification_error   String?
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt
  answered_at          DateTime?

  @@index([requester_identifier])
  @@index([requester_email])
  @@index([status])
  @@index([category])
  @@index([created_at])
}
